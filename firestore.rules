rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public access for this specific app's collections
    match /master_prompts/{promptId} {
      allow read, write: if true;
    }

    match /generations/{generationId} {
      allow read, write: if true;
    }
    
    match /users/{userId} {
      allow read, write: if true;
    }
  }
}
