{
  "entities": {
    "MasterPrompt": {
      "title": "Master Prompt",
      "description": "A system instruction template for the AI generator.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the prompt template." },
        "content": { "type": "string", "description": "The full text of the master prompt." },
        "isActive": { "type": "boolean", "description": "Whether this prompt is currently active." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp." }
      },
      "required": ["name", "content", "isActive"]
    },
    "Generation": {
      "title": "Generation",
      "description": "A set of generated scene prompts based on a script.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user ID of the creator." },
        "script": { "type": "string", "description": "The input script provided by the user." },
        "characterRef": { "type": "string", "description": "Optional character reference description." },
        "prompts": { "type": "array", "items": { "type": "string" }, "description": "The generated cinematic scene prompts." },
        "promptId": { "type": "string", "description": "The ID of the master prompt used for this generation." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." }
      },
      "required": ["uid", "script", "prompts", "promptId", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "A user profile.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The display name of the user." },
        "email": { "type": "string", "description": "The email of the user." },
        "photoUrl": { "type": "string", "description": "The photo URL of the user." },
        "role": { "type": "string", "description": "The role of the user (e.g., admin, user)." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp." }
      },
      "required": ["name", "email"]
    }
  },
  "firestore": {
    "/master_prompts/{promptId}": {
      "schema": "MasterPrompt",
      "description": "Collection of master prompt templates."
    },
    "/generations/{generationId}": {
      "schema": "Generation",
      "description": "Collection of generated scene outputs."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles."
    }
  }
}
